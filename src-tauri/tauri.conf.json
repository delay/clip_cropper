{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clip Cropper",
  "version": "0.1.0",
  "identifier": "com.delay.clipcropper",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clip Cropper",
        "width": 1460,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**/*"]
      }
    }
  },
  "bundle": {
    "active": false
  }
}
